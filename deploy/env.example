# Copy to deploy/.env and fill in values. Never commit deploy/.env.

HCLOUD_TOKEN=
HETZNER_ROBOT_USER=
HETZNER_ROBOT_PASSWORD=

SSH_KEY_NAME=ssh_key
HETZNER_SSH_PUB_PATH=${HOME}/.ssh/id_ed25519.pub
HETZNER_SSH_PRIV_PATH=${HOME}/.ssh/id_ed25519

CLUSTER_NAME=my-cluster
MGMT_CLUSTER_NAME=hetzner-mgmt

HCLOUD_REGION=sin
HCLOUD_CONTROL_PLANE_MACHINE_TYPE=cpx32
HCLOUD_WORKER_MACHINE_TYPE=cpx32

KUBERNETES_VERSION=1.36.1
CONTROL_PLANE_MACHINE_COUNT=1
WORKER_MACHINE_COUNT=3

CAPI_INFRA_VERSION=hetzner:v1.1.4
CAPI_FLAVOR=hetzner-hcloud-control-planes

OUTPUT_DIR=output
